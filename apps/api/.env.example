NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173

# GigaChat secrets live only in the API runtime.
# Authorization key from GigaChat Studio. Never expose it to apps/web.
GIGACHAT_CREDENTIALS=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
# Local corporate/self-signed certificate workaround. Keep false in production.
GIGACHAT_ALLOW_SELF_SIGNED=false

AI_PROVIDER=gigachat
AI_DEFAULT_MODEL=GigaChat
ENABLED_PROVIDERS=gigachat

RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000
